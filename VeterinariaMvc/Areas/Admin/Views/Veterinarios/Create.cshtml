@model VeterinariaMvc.Dtos.Veterinarios.RegisterVeterinarioDto
@{
    ViewData["Title"] = "Añadir Veterinario";
}

<div class="flex flex-col items-center mb-6">
    <div class="h-14 w-14 bg-blue-500 rounded-full flex items-center justify-center shadow-md mb-3 transition hover:scale-105">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-7 w-7 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                  d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
        </svg>
    </div>

    <p class="text-center text-sm text-slate-500">
        Añade un nuevo veterinario al equipo de <span class="font-bold text-blue-600">VetCare</span>.
    </p>
</div>

<div asp-validation-summary="ModelOnly"
     class="text-sm text-red-600 bg-red-50 p-3 rounded-lg mb-4"
     style="display: @(ViewData.ModelState.IsValid ? "none" : "block")">
</div>

<form class="space-y-4"  method="POST" enctype="multipart/form-data">

    <input type="hidden" asp-for="Rol" value="@((int)VeterinariaMvc.Models.Enums.Roles.Veterinario)" />
    <input type="hidden" asp-for="IdClinica" />

    <div>
        <label asp-for="Nombre" class="block text-sm font-medium text-slate-700 mb-1">Nombre completo</label>
        <input asp-for="Nombre" type="text" autocomplete="name"
               placeholder="Ej: Dra. Ana García"
               class="block w-full px-4 py-2.5 border border-slate-300 rounded-lg shadow-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500 sm:text-sm">
        <span asp-validation-for="Nombre" class="text-xs text-red-500 mt-1 block"></span>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        <div>
            <label asp-for="Email" class="block text-sm font-medium text-slate-700 mb-1">Correo electrónico</label>
            <input asp-for="Email" type="email" autocomplete="email"
                   placeholder="doctora@clinica.com"
                   class="block w-full px-4 py-2.5 border border-slate-300 rounded-lg shadow-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500 sm:text-sm">
            <span asp-validation-for="Email" class="text-xs text-red-500 mt-1 block"></span>
        </div>

        <div>
            <label asp-for="Telefono" class="block text-sm font-medium text-slate-700 mb-1">
                Teléfono <span class="text-slate-400 font-normal">(Opcional)</span>
            </label>
            <input asp-for="Telefono" type="tel" autocomplete="tel"
                   placeholder="+34 600 000 000"
                   class="block w-full px-4 py-2.5 border border-slate-300 rounded-lg shadow-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500 sm:text-sm">
            <span asp-validation-for="Telefono" class="text-xs text-red-500 mt-1 block"></span>
        </div>
    </div>

    <div>
        <label asp-for="NumeroColegiado" class="block text-sm font-medium text-slate-700 mb-1">
            Número de Colegiado <span class="text-slate-400 font-normal">(Opcional)</span>
        </label>
        <input asp-for="NumeroColegiado" type="text"
               placeholder="Ej: COL-12345"
               class="block w-full px-4 py-2.5 border border-slate-300 rounded-lg shadow-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500 sm:text-sm">
        <span asp-validation-for="NumeroColegiado" class="text-xs text-red-500 mt-1 block"></span>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        <div>
            <label asp-for="Password" class="block text-sm font-medium text-slate-700 mb-1">Contraseña temporal</label>
            <input asp-for="Password" type="password" autocomplete="new-password"
                   placeholder="••••••••"
                   class="block w-full px-4 py-2.5 border border-slate-300 rounded-lg shadow-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500 sm:text-sm">
            <span asp-validation-for="Password" class="text-xs text-red-500 mt-1 block"></span>
        </div>

        <div>
            <label asp-for="ConfirmarPassword" class="block text-sm font-medium text-slate-700 mb-1">Confirmar contraseña</label>
            <input asp-for="ConfirmarPassword" type="password" autocomplete="new-password"
                   placeholder="••••••••"
                   class="block w-full px-4 py-2.5 border border-slate-300 rounded-lg shadow-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500 sm:text-sm">
            <span asp-validation-for="ConfirmarPassword" class="text-xs text-red-500 mt-1 block"></span>
        </div>
    </div>

    <div>
        <label class="block text-sm font-medium text-slate-700 mb-2">
            Foto de perfil <span class="text-slate-400 font-normal">(Opcional)</span>
        </label>

        <div id="dropzone"
             class="flex items-center gap-4 p-4 border-2 border-dashed border-slate-300 rounded-xl hover:border-blue-500 transition-all duration-200 cursor-pointer group">

            <div class="h-20 w-20 shrink-0 rounded-full border border-slate-200 shadow-sm bg-slate-100 flex items-center justify-center overflow-hidden">
                <img id="preview" src="" class="h-full w-full object-cover hidden" />
                <div id="cameraIcon" class="text-slate-400 group-hover:text-blue-500 transition-colors">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M3 7h3l2-2h8l2 2h3v12H3V7z" />
                        <circle cx="12" cy="13" r="4" stroke-width="1.8" />
                    </svg>
                </div>
            </div>

            <div class="flex flex-col text-sm text-slate-600 overflow-hidden w-full">
                <span class="font-medium text-blue-600 group-hover:text-blue-500">Subir imagen</span>
                <span class="text-xs text-slate-400">Arrastra o haz clic</span>
                <span id="file-name" class="text-xs text-slate-400 mt-1 truncate">Ningún archivo seleccionado</span>
            </div>

            <input asp-for="Imagen" id="Imagen" type="file" accept="image/*" class="hidden">
        </div>
        <span asp-validation-for="Imagen" class="text-xs text-red-500 mt-1 block"></span>
    </div>

    <div class="pt-4">
        <button type="submit"
                class="w-full hover:cursor-pointer py-3 rounded-lg shadow-md text-sm font-bold text-white bg-blue-600 hover:bg-blue-700 focus:ring-2 focus:ring-offset-2 focus:ring-blue-500 transition uppercase tracking-wider">
            Registrar Veterinario
        </button>
    </div>
</form>

<div class="mt-6 text-center">
    <a asp-action="Index" asp-controller="Clinica"
       class="text-sm text-slate-600 hover:text-blue-600 transition">
        Volver al panel de la clínica
    </a>
</div>

@if (ViewData["ERROR"] != null)
{
    <h1 class="text-center text-red-500 mt-4 font-semibold">
        @ViewData["ERROR"]
    </h1>
}

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
    <script>
        const dropzone = document.getElementById('dropzone');
        const fileInput = document.getElementById('Imagen');
        const preview = document.getElementById('preview');
        const cameraIcon = document.getElementById('cameraIcon');
        const fileNameDisplay = document.getElementById('file-name');

        ['dragenter', 'dragover', 'dragleave', 'drop'].forEach(ev => {
            dropzone.addEventListener(ev, e => { e.preventDefault(); e.stopPropagation(); });
        });

        ['dragenter', 'dragover'].forEach(ev => {
            dropzone.addEventListener(ev, () => dropzone.classList.add('border-blue-500', 'bg-blue-50'));
        });
        ['dragleave', 'drop'].forEach(ev => {
            dropzone.addEventListener(ev, () => dropzone.classList.remove('border-blue-500', 'bg-blue-50'));
        });

        dropzone.addEventListener('drop', (e) => {
            const files = e.dataTransfer.files;
            if (files.length > 0) {
                fileInput.files = files;
                updatePreview(files[0]);
            }
        });

        dropzone.addEventListener('click', () => fileInput.click());

        fileInput.addEventListener('change', function () {
            if (this.files.length > 0) updatePreview(this.files[0]);
        });

        function updatePreview(file) {
            fileNameDisplay.textContent = file.name;
            const reader = new FileReader();
            reader.onload = function (e) {
                preview.src = e.target.result;
                preview.classList.remove('hidden');
                preview.style.display = 'block';
                cameraIcon.classList.add('hidden');
                cameraIcon.style.display = 'none';
            }
            reader.readAsDataURL(file);
        }
    </script>
}