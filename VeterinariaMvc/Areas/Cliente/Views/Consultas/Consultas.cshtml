@using VeterinariaMvc.Dtos.Consultas.VeterinariaMvc.Dtos.Consulta
@model List<ConsultaResumen>

@{
    ViewData["Title"] = "Historial de Citas";
}

<div class="space-y-6">
    <div class="flex flex-col md:flex-row md:items-center justify-between gap-4">
        <div>
            <div class="flex items-center gap-3">
                <a asp-action="Index" asp-controller="Home" class="p-2 bg-slate-100 text-slate-500 rounded-full hover:bg-slate-200 transition-colors">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
                    </svg>
                </a>
                <h2 class="text-3xl font-bold text-slate-800">Historial de Citas</h2>
            </div>
            <p class="text-slate-500 mt-1 ml-11">Registro completo de todas las consultas médicas de tus mascotas.</p>
        </div>
    </div>

    <div class="bg-white rounded-2xl shadow-sm border border-slate-100 overflow-hidden">

        @if (Model != null && Model.Any())
        {
            <div class="overflow-x-auto">
                <table class="w-full text-left border-collapse">
                    <thead>
                        <tr class="bg-slate-50 text-slate-500 text-sm border-b border-slate-100">
                            <th class="p-4 font-semibold">Fecha y Hora</th>
                            <th class="p-4 font-semibold">Mascota</th>
                            <th class="p-4 font-semibold">Clínica</th>
                            <th class="p-4 font-semibold">Motivo</th>
                            <th class="p-4 font-semibold text-center">Estado</th>
                            <th class="p-4 font-semibold text-center">Acciones</th>
                        </tr>
                    </thead>
                    <tbody class="text-sm text-slate-700">
                        @foreach (var cita in Model)
                        {
                            <tr class="border-b border-slate-50 hover:bg-slate-50 transition-colors @(cita.Estado?.ToUpper() == "CANCELADA" ? "opacity-60 bg-slate-50/50" : "")">
                                <td class="p-4">
                                    <div class="flex flex-col">
                                        <span class="font-bold text-slate-800">@cita.Fecha.ToString("dd MMM yyyy")</span>
                                        <span class="text-slate-500 text-xs font-medium">@cita.Fecha.ToString("HH:mm")</span>
                                    </div>
                                </td>
                                <td class="p-4 font-semibold text-slate-800">@cita.NombreMascota</td>
                                <td class="p-4 text-slate-600">@cita.NombreClinica</td>
                                <td class="p-4 text-slate-600">@cita.Motivo</td>
                                <td class="p-4 text-center">
                                    @switch (cita.Estado?.ToUpper())
                                    {
                                        case "CONFIRMADA":
                                            <span class="bg-emerald-100 text-emerald-700 text-xs font-bold px-3 py-1 rounded-full border border-emerald-200">Confirmada</span>
                                            break;
                                        case "PENDIENTE":
                                            <span class="bg-amber-100 text-amber-700 text-xs font-bold px-3 py-1 rounded-full border border-amber-200">Pendiente</span>
                                            break;
                                        case "CANCELADA":
                                            <span class="bg-red-50 text-red-500 text-xs font-bold px-3 py-1 rounded-full border border-red-100">Cancelada</span>
                                            break;
                                        case "COMPLETADA":
                                        case "FINALIZADA":
                                            <span class="bg-blue-100 text-blue-700 text-xs font-bold px-3 py-1 rounded-full border border-blue-200">Completada</span>
                                            break;
                                        default:
                                            <span class="bg-slate-100 text-slate-600 text-xs font-bold px-3 py-1 rounded-full">@cita.Estado</span>
                                            break;
                                    }
                                </td>
                                <td class="p-4 text-center">
                                    @{
                                        // LÓGICA DE CANCELACIÓN:
                                        // Solo mostramos el botón si la cita es en el futuro Y no está ya cancelada o finalizada
                                        bool esCancelable = cita.Fecha > DateTime.Now
                                        && cita.Estado?.ToUpper() != "CANCELADA"
                                        && cita.Estado?.ToUpper() != "COMPLETADA"
                                        && cita.Estado?.ToUpper() != "FINALIZADA";
                                    }

                                    @if (esCancelable)
                                    {
                                        <form asp-controller="Consultas" asp-action="Cancelar" asp-route-id="@cita.IdConsulta" method="post" class="inline m-0 p-0" onsubmit="return confirm('¿Estás seguro de que deseas cancelar esta cita?');">
                                            <button type="submit" id="cancelarCita_@cita.IdConsulta" class="text-red-500 hover:text-red-700 font-bold text-sm transition-colors hover:underline bg-transparent border-none p-0 cursor-pointer">
                                                Cancelar
                                            </button>
                                        </form>
                                    }
                                    else
                                    {
                                        <span class="text-slate-300 text-sm italic cursor-not-allowed" title="Esta cita ya no se puede modificar">-</span>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <div class="p-16 text-center text-slate-500">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-16 w-16 mx-auto text-slate-200 mb-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-3 7h3m-3 4h3m-6-4h.01M9 16h.01" />
                </svg>
                <p class="text-lg font-medium text-slate-600">No hay registros en tu historial.</p>
                <p class="text-sm mt-1">Aún no has tenido ninguna consulta con nosotros.</p>
            </div>
        }
    </div>
</div>