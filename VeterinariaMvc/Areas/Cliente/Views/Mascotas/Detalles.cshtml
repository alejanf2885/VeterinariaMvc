@model VeterinariaMvc.Dtos.Mascota.MascotaDetalleDto

@{
    ViewData["Title"] = "Ficha de " + Model.NombreMascota;
}

<div class="space-y-8 max-w-5xl mx-auto relative">
    <div class="flex flex-col md:flex-row md:items-center justify-between gap-4">
        <div>
            <h2 class="text-3xl font-bold text-slate-800">Ficha Médica 📋</h2>
            <p class="text-slate-500">Consulta la información detallada y el historial de tu mascota.</p>
        </div>

        <a asp-area="Cliente" asp-controller="Home" asp-action="Index"
           class="inline-flex items-center text-slate-500 hover:text-slate-800 font-semibold transition-colors">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 mr-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
            </svg>
            Volver al Panel
        </a>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
        <div class="lg:col-span-2 space-y-6">
            <div class="bg-white rounded-2xl shadow-sm border border-slate-100 overflow-hidden relative">
                <div class="p-8 flex flex-col md:flex-row gap-8 items-center md:items-start">
                    <div class="h-48 w-48 shrink-0 rounded-3xl border-4 border-slate-50 shadow-md overflow-hidden bg-slate-100 relative group">
                        <img src="@(string.IsNullOrEmpty(Model.ImagenMascota) ? "/images/mascotas/default-avatar.png" : Model.ImagenMascota)"
                             class="h-full w-full object-cover"
                             alt="@Model.NombreMascota" />
                    </div>

                    <div class="flex-1 space-y-4 text-center md:text-left">
                        <div>
                            <span class="px-3 py-1 bg-teal-100 text-teal-700 text-xs font-bold rounded-full uppercase tracking-wider">
                                @Model.Especie
                            </span>
                            <h1 class="text-4xl font-black text-slate-800 mt-2">@Model.NombreMascota</h1>
                            <p class="text-xl text-slate-500">@Model.Raza</p>
                        </div>

                        <div class="grid grid-cols-2 gap-4 pt-4">
                            <div class="p-4 bg-slate-50 rounded-xl border border-slate-100 flex flex-col justify-center items-center md:items-start">
                                <p class="text-xs font-bold text-slate-400 uppercase">Peso Actual</p>
                                <p class="text-xl font-bold text-slate-800">@(Model.Peso?.ToString("N2") ?? "---") <span class="text-sm font-medium">kg</span></p>
                            </div>
                            <div class="p-4 bg-slate-50 rounded-xl border border-slate-100 flex flex-col justify-center items-center md:items-start">
                                <p class="text-xs font-bold text-slate-400 uppercase">Estado Salud</p>
                                <p class="text-xl font-bold text-teal-600">@(Model.EstadoEnClinica ?? "Estable")</p>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="bg-slate-50 px-8 py-4 border-t border-slate-100 flex flex-wrap justify-center md:justify-end gap-3 items-center">

                    <button onclick="document.getElementById('modalEliminar').showModal()"
                            class="p-2 text-slate-400 hover:text-red-600 hover:bg-red-50 rounded-lg transition-colors group"
                            title="Eliminar mascota">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 group-hover:scale-110 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
                        </svg>
                    </button>

                    <div class="hidden md:block w-px h-6 bg-slate-200 mx-1"></div>

                    <a asp-area="Cliente" asp-controller="Mascotas" asp-action="Editar" asp-route-id="@Model.IdMascota"
                       class="px-4 py-2 text-sm font-bold text-teal-600 hover:bg-teal-100 rounded-lg transition-colors">
                        Editar Perfil
                    </a>

                    <button class="px-4 py-2 text-sm font-bold bg-teal-600 text-white rounded-lg shadow-md hover:bg-teal-700 transition-all flex items-center gap-2">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
                        </svg>
                        Solicitar Cita
                    </button>
                </div>
            </div>

            <div class="bg-white rounded-2xl shadow-sm border border-slate-100 p-6">
                <h3 class="text-lg font-bold text-slate-800 mb-4">Últimas Actividades</h3>
                <div class="text-center py-8">
                    <div class="bg-slate-50 rounded-full h-16 w-16 flex items-center justify-center mx-auto mb-3">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8 text-slate-300" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
                        </svg>
                    </div>
                    <p class="text-slate-400 text-sm">No hay consultas recientes registradas.</p>
                </div>
            </div>
        </div>

        <div class="space-y-6">
            <div class="bg-white rounded-2xl shadow-sm border border-slate-100 overflow-hidden">
                <div class="p-6 bg-slate-800 text-white">
                    <h3 class="font-bold flex items-center gap-2">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-teal-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-10V4m0 10V4m-4 14h.01" />
                        </svg>
                        Centro Veterinario
                    </h3>
                </div>
                <div class="p-6 space-y-4">
                    @if (!string.IsNullOrEmpty(Model.NombreClinica))
                    {
                        <div>
                            <p class="text-xs font-bold text-slate-400 uppercase tracking-widest">Nombre</p>
                            <p class="text-slate-700 font-semibold">@Model.NombreClinica</p>
                        </div>
                        <div>
                            <p class="text-xs font-bold text-slate-400 uppercase tracking-widest">Dirección</p>
                            <p class="text-slate-600 text-sm italic">@Model.DireccionClinica</p>
                        </div>
                        <div class="pt-2">
                            <span class="inline-flex items-center px-2.5 py-0.5 rounded-md text-sm font-medium bg-blue-50 text-blue-700 border border-blue-100">
                                <svg class="-ml-0.5 mr-1.5 h-2 w-2 text-blue-400" fill="currentColor" viewBox="0 0 8 8">
                                    <circle cx="4" cy="4" r="3" />
                                </svg>
                                Paciente @Model.EstadoEnClinica
                            </span>
                        </div>
                    }
                    else
                    {
                        <div class="text-center py-4">
                            <p class="text-slate-400 text-sm">Mascota no vinculada a ninguna clínica actualmente.</p>
                            <button class="mt-3 text-teal-600 text-sm font-bold hover:underline">Vincular ahora</button>
                        </div>
                    }
                </div>
            </div>

            <div class="bg-teal-600 rounded-2xl p-6 text-white shadow-lg shadow-teal-100">
                <h4 class="font-bold mb-2 flex items-center gap-2">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                    </svg>
                    ¿Necesitas ayuda?
                </h4>
                <p class="text-teal-100 text-sm mb-4">Si los datos no son correctos, contacta con tu centro veterinario asignado.</p>
                <a href="#" class="block w-full text-center py-2 bg-white text-teal-600 font-bold rounded-lg text-sm hover:bg-teal-50 transition-colors">
                    Contactar Soporte
                </a>
            </div>
        </div>
    </div>
</div>

<dialog id="modalEliminar" class="p-6 rounded-2xl shadow-2xl bg-white w-full max-w-md border-0 focus:outline-none backdrop:bg-slate-900/50 backdrop:backdrop-blur-sm open:animate-fade-in">

    <div class="flex flex-col items-center text-center mb-6 pt-2">
        <div class="h-14 w-14 bg-red-100 text-red-600 rounded-full flex items-center justify-center mb-4">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-7 w-7" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" />
            </svg>
        </div>
        <h3 class="text-xl font-bold text-slate-800 mb-2">¿Dar de baja a @Model.NombreMascota?</h3>
        <p class="text-slate-500 text-sm">
            Esta acción desactivará el perfil de tu mascota. No se eliminará su historial clínico, pero dejará de aparecer en tu panel principal.
        </p>
    </div>

    <div class="flex flex-col-reverse md:flex-row gap-3">
        <form method="dialog" class="w-full md:w-1/2">
            <button class="w-full px-4 py-2.5 bg-slate-100 hover:bg-slate-200 text-slate-700 font-semibold rounded-xl transition-colors duration-200">
                Cancelar
            </button>
        </form>

        <form asp-controller="Mascotas" asp-action="Desactivar" method="post" class="w-full md:w-1/2">
            <input type="hidden" name="idMascota" value="@Model.IdMascota" />
            <button type="submit" class="w-full px-4 py-2.5 bg-red-600 hover:bg-red-700 text-white font-semibold rounded-xl shadow-sm hover:shadow transition-all duration-200">
                Sí, dar de baja
            </button>
        </form>
    </div>
</dialog>