@using VeterinariaMvc.Areas.Cliente.Models
@model EditarMascotaViewModel

@{
    ViewData["Title"] = "Editar Mascota";
}

<div class="space-y-8 max-w-4xl mx-auto">
    <div class="flex flex-col md:flex-row md:items-center justify-between gap-4">
        <div>
            <h2 class="text-3xl font-bold text-slate-800">Editar Mascota 🐾</h2>
            <p class="text-slate-500">Actualiza los datos de tu compañero peludo.</p>
        </div>

        <a asp-area="Cliente" asp-controller="Home" asp-action="Index"
           class="inline-flex items-center text-slate-500 hover:text-slate-800 font-semibold transition-colors">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 mr-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
            </svg>
            Volver al Panel
        </a>
    </div>

    <div class="bg-white rounded-2xl shadow-sm border border-slate-100 overflow-hidden">
        <div class="p-6 border-b border-slate-100">
            <h3 class="text-lg font-bold text-slate-800">Información General</h3>
        </div>

        <form asp-action="Editar" method="post" class="p-6 md:p-8">
            <div class="grid grid-cols-1 md:grid-cols-2 gap-8">

                <div class="space-y-6">
                    <div>
                        <label asp-for="Formulario.Nombre" class="block text-sm font-semibold text-slate-700 mb-2">Nombre de la mascota *</label>
                        <input asp-for="Formulario.Nombre" class="w-full px-4 py-3 rounded-xl border border-slate-200 focus:ring-2 focus:ring-teal-500 focus:border-teal-500 transition-colors text-slate-800 bg-slate-50 focus:bg-white placeholder-slate-400" placeholder="Ej. Max, Luna..." />
                        <span asp-validation-for="Formulario.Nombre" class="text-red-500 text-xs mt-1"></span>
                    </div>

                    <div class="grid grid-cols-2 gap-4">
                        <div>
                            <label asp-for="Formulario.IdEspecie" class="block text-sm font-semibold text-slate-700 mb-2">Especie *</label>
                            <select id="selectEspecie" asp-for="Formulario.IdEspecie" class="w-full px-4 py-3 rounded-xl border border-slate-200 focus:ring-2 focus:ring-teal-500 focus:border-teal-500 transition-colors text-slate-800 bg-slate-50 focus:bg-white appearance-none">
                                <option value="">Seleccione...</option>
                                @foreach (var esp in Model.Catalogos.Especies)
                                {
                                    <option value="@esp.Id">@esp.Nombre</option>
                                }
                            </select>
                            <span asp-validation-for="Formulario.IdEspecie" class="text-red-500 text-xs mt-1"></span>
                        </div>

                        <div>
                            <label asp-for="Formulario.IdRaza" class="block text-sm font-semibold text-slate-700 mb-2">Raza</label>
                            <select id="selectRaza" asp-for="Formulario.IdRaza" class="w-full px-4 py-3 rounded-xl border border-slate-200 focus:ring-2 focus:ring-teal-500 focus:border-teal-500 transition-colors text-slate-800 bg-slate-50 focus:bg-white appearance-none">
                                <option value="" data-especie="0">Seleccione...</option>
                                @foreach (var raza in Model.Catalogos.Razas)
                                {
                                    <option value="@raza.Id" data-especie="@raza.IdEspecie" style="display:none;">@raza.Nombre</option>
                                }
                            </select>
                        </div>
                    </div>

                    <div class="grid grid-cols-2 gap-4">
                        <div>
                            <label asp-for="Formulario.Sexo" class="block text-sm font-semibold text-slate-700 mb-2">Sexo</label>
                            <select asp-for="Formulario.Sexo" class="w-full px-4 py-3 rounded-xl border border-slate-200 focus:ring-2 focus:ring-teal-500 focus:border-teal-500 transition-colors text-slate-800 bg-slate-50 focus:bg-white appearance-none">
                                <option value="">Seleccione...</option>
                                <option value="Macho">Macho</option>
                                <option value="Hembra">Hembra</option>
                            </select>
                        </div>

                        <div>
                            <label asp-for="Formulario.PesoActual" class="block text-sm font-semibold text-slate-700 mb-2">Peso (kg)</label>
                            <input asp-for="Formulario.PesoActual" type="number" step="0.01" class="w-full px-4 py-3 rounded-xl border border-slate-200 focus:ring-2 focus:ring-teal-500 focus:border-teal-500 transition-colors text-slate-800 bg-slate-50 focus:bg-white placeholder-slate-400" placeholder="Ej. 5.5" />
                        </div>
                    </div>
                </div>

                <div class="space-y-6">
                    <div>
                        <label asp-for="Formulario.FechaNacimiento" class="block text-sm font-semibold text-slate-700 mb-2">Fecha de Nacimiento</label>
                        <input asp-for="Formulario.FechaNacimiento" type="date" class="w-full px-4 py-3 rounded-xl border border-slate-200 focus:ring-2 focus:ring-teal-500 focus:border-teal-500 transition-colors text-slate-800 bg-slate-50 focus:bg-white" />
                    </div>
                </div>
            </div>

            <div class="mt-10 flex items-center justify-end gap-4 pt-6 border-t border-slate-100">
                <a asp-area="Cliente" asp-controller="Home" asp-action="Index" class="px-6 py-3 text-slate-600 font-semibold hover:bg-slate-100 rounded-xl transition-colors">
                    Cancelar
                </a>
                <button type="submit" class="px-8 py-3 bg-teal-600 text-white font-bold rounded-xl shadow-lg hover:bg-teal-700 transition-all transform hover:-translate-y-1 flex items-center">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                    </svg>
                    Guardar cambios
                </button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        // misma lógica de filtrado de razas que en Registrar
        document.getElementById('selectEspecie').addEventListener('change', function () {
            var especieId = this.value;
            var selectRaza = document.getElementById('selectRaza');
            var opciones = selectRaza.querySelectorAll('option');

            selectRaza.value = "";

            opciones.forEach(function (opcion) {
                var dataEspecie = opcion.getAttribute('data-especie');
                if (dataEspecie === "0" || dataEspecie === especieId) {
                    opcion.style.display = 'block';
                } else {
                    opcion.style.display = 'none';
                }
            });
        });
    </script>
}

