@model VeterinariaMvc.Areas.Cliente.Models.TratamientoDetalleViewModel

@{
    ViewData["Title"] = "Detalle del Tratamiento";
}

<div class="space-y-8">
    <div class="flex items-center gap-3">
        <a asp-action="Index" class="text-teal-600 hover:text-teal-800">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
            </svg>
        </a>
        <h2 class="text-3xl font-bold text-slate-800">Detalle del Tratamiento</h2>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="bg-green-100 border border-green-400 text-green-700 px-4 py-3 rounded-xl">
            @TempData["Success"]
        </div>
    }

    @if (TempData["Error"] != null)
    {
        <div class="bg-red-100 border border-red-400 text-red-700 px-4 py-3 rounded-xl">
            @TempData["Error"]
        </div>
    }

    <!-- Información del Tratamiento -->
    <div class="bg-white rounded-2xl shadow-sm border border-slate-100 p-6">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <div>
                <h3 class="text-sm font-semibold text-slate-500 uppercase mb-1">Tratamiento</h3>
                <p class="text-xl font-bold text-slate-800">@Model.Tratamiento.Nombre</p>
            </div>

            <div>
                <h3 class="text-sm font-semibold text-slate-500 uppercase mb-1">Estado</h3>
                @if (Model.Tratamiento.Estado?.ToUpper() == "ACTIVO")
                {
                    <span class="bg-emerald-100 text-emerald-700 text-sm font-bold px-4 py-2 rounded-full inline-block">Activo</span>
                }
                else if (Model.Tratamiento.Estado?.ToUpper() == "COMPLETADO")
                {
                    <span class="bg-blue-100 text-blue-700 text-sm font-bold px-4 py-2 rounded-full inline-block">Completado</span>
                }
                else if (Model.Tratamiento.Estado?.ToUpper() == "SUSPENDIDO")
                {
                    <span class="bg-amber-100 text-amber-700 text-sm font-bold px-4 py-2 rounded-full inline-block">Suspendido</span>
                }
                else
                {
                    <span class="bg-slate-100 text-slate-600 text-sm font-bold px-4 py-2 rounded-full inline-block">@Model.Tratamiento.Estado</span>
                }
            </div>

            <div>
                <h3 class="text-sm font-semibold text-slate-500 uppercase mb-1">Mascota</h3>
                <p class="text-lg font-semibold text-slate-800">@Model.Tratamiento.NombreMascota</p>
            </div>

            <div>
                <h3 class="text-sm font-semibold text-slate-500 uppercase mb-1">Veterinario</h3>
                <p class="text-lg font-semibold text-slate-800">@Model.Tratamiento.NombreVeterinario</p>
            </div>

            <div>
                <h3 class="text-sm font-semibold text-slate-500 uppercase mb-1">Fecha de Inicio</h3>
                <p class="text-lg text-slate-800">@Model.Tratamiento.FechaInicio.ToString("dd 'de' MMMM 'de' yyyy", new System.Globalization.CultureInfo("es-ES"))</p>
            </div>

            <div>
                <h3 class="text-sm font-semibold text-slate-500 uppercase mb-1">Fecha de Finalización</h3>
                @if (Model.Tratamiento.FechaFin.HasValue)
                {
                    <p class="text-lg text-slate-800">@Model.Tratamiento.FechaFin.Value.ToString("dd 'de' MMMM 'de' yyyy", new System.Globalization.CultureInfo("es-ES"))</p>
                }
                else
                {
                    <p class="text-lg text-slate-400 italic">En curso</p>
                }
            </div>

            @if (!string.IsNullOrEmpty(Model.Tratamiento.Descripcion))
            {
                <div class="md:col-span-2">
                    <h3 class="text-sm font-semibold text-slate-500 uppercase mb-1">Descripción</h3>
                    <p class="text-slate-700">@Model.Tratamiento.Descripcion</p>
                </div>
            }
        </div>
    </div>

    <!-- Agregar Seguimiento -->
    <div class="bg-white rounded-2xl shadow-sm border border-slate-100 p-6">
        <h3 class="text-lg font-bold text-slate-800 mb-4">✍️ Agregar Seguimiento</h3>
        <p class="text-sm text-slate-600 mb-4">
            Comparte cómo va evolucionando el tratamiento. Tu veterinario podrá ver tus comentarios.
        </p>

        <form asp-action="AgregarSeguimiento" asp-route-id="@Model.Tratamiento.Id" method="post" class="space-y-4">
            <div>
                <label for="comentario" class="block text-sm font-semibold text-slate-700 mb-2">
                    Comentario
                </label>
                <textarea 
                    id="comentario" 
                    name="comentario" 
                    rows="4" 
                    required
                    class="w-full px-4 py-3 border border-slate-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-teal-500 focus:border-transparent"
                    placeholder="Ej: La mascota ha mostrado mejoría, está más activa y con mejor apetito..."></textarea>
            </div>

            <div class="flex justify-end">
                <button 
                    type="submit" 
                    class="px-6 py-3 bg-teal-600 text-white font-bold rounded-xl shadow-lg hover:bg-teal-700 transition-all transform hover:-translate-y-1">
                    Guardar Seguimiento
                </button>
            </div>
        </form>
    </div>

    <!-- Historial de Seguimiento -->
    <div class="bg-white rounded-2xl shadow-sm border border-slate-100 overflow-hidden">
        <div class="p-6 border-b border-slate-100">
            <h3 class="text-lg font-bold text-slate-800">📋 Historial de Seguimiento</h3>
        </div>

        @if (Model.Tratamiento.Seguimientos != null && Model.Tratamiento.Seguimientos.Any())
        {
            <div class="p-6 space-y-4">
                @foreach (var seguimiento in Model.Tratamiento.Seguimientos)
                {
                    <div class="border-l-4 border-teal-500 bg-slate-50 rounded-r-xl p-4">
                        <div class="flex items-start justify-between mb-2">
                            <div class="flex items-center gap-2">
                                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-teal-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
                                </svg>
                                <span class="font-semibold text-slate-800">@seguimiento.NombreUsuario</span>
                            </div>
                            <span class="text-sm text-slate-500">
                                @seguimiento.Fecha.ToString("dd/MM/yyyy HH:mm")
                            </span>
                        </div>
                        <p class="text-slate-700 ml-7">@seguimiento.Comentario</p>
                    </div>
                }
            </div>
        }
        else
        {
            <div class="p-12 text-center text-slate-500">
                <p>Aún no hay seguimientos registrados.</p>
                <p class="text-sm mt-2">Sé el primero en agregar un comentario sobre la evolución del tratamiento.</p>
            </div>
        }
    </div>
</div>
