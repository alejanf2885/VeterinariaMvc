@model VeterinariaMvc.Areas.Veterinario.Models.DashboardVeterinarioViewModel
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Citas";
}

<div class="mb-6">
    <h1 class="text-2xl font-bold text-slate-800">Todas tus citas</h1>
    <p class="text-slate-500 mt-1">Listado completo de citas asignadas.</p>
</div>

<div class="bg-white rounded-xl shadow-sm border border-slate-200 overflow-hidden">
    <div class="overflow-x-auto">
        <table class="w-full text-sm text-left text-slate-600">
            <thead class="text-xs uppercase bg-slate-50 text-slate-500 border-b border-slate-200">
                <tr>
                    <th class="px-6 py-3">Fecha / Hora</th>
                    <th class="px-6 py-3">Mascota</th>
                    <th class="px-6 py-3">Dueńo</th>
                    <th class="px-6 py-3">Motivo</th>
                    <th class="px-6 py-3">Estado</th>
                    <th class="px-6 py-3">Acciones</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-slate-100">
                @foreach (var c in Model.CitasAsignadas)
                {
                    <tr class="hover:bg-slate-50 transition">
                        <td class="px-6 py-4 font-medium text-slate-900">
                            @c.FechaHoraConsulta.ToString("dd/MM/yyyy HH:mm")
                        </td>
                        <td class="px-6 py-4">@c.NombreMascota</td>
                        <td class="px-6 py-4">@c.NombreDueno</td>
                        <td class="px-6 py-4">@c.Motivo</td>
                        <td class="px-6 py-4">@c.Estado</td>
                        <td class="px-6 py-4">
                            <a asp-area="Veterinario"
                               asp-controller="Tratamientos"
                               asp-action="Create"
                               asp-route-idConsulta="@c.IdConsulta"
                               asp-route-idMascota="@c.IdMascota"
                               asp-route-nombreMascota="@c.NombreMascota"
                               asp-route-idVeterinario="@c.IdVeterinario"
                               class="inline-flex items-center gap-1 px-3 py-1.5 text-xs font-semibold rounded-md bg-teal-600 text-white hover:bg-teal-700">
                                Crear tratamiento
                            </a>
                        </td>
                    </tr>
                }
                @if (Model.CitasAsignadas.Count == 0)
                {
                    <tr>
                        <td colspan="5" class="px-6 py-8 text-center text-slate-500">
                            No tienes citas asignadas.
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
