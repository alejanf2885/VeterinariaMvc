@model VeterinariaMvc.Areas.Veterinario.Models.PlantillaDetalleViewModel
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Eliminar Plantilla";
}

<div class="max-w-xl mx-auto mt-6">
    <div class="bg-white rounded-2xl shadow border border-red-200 overflow-hidden">
        <div class="px-6 py-4 border-b border-red-200 bg-red-50">
            <h1 class="text-xl font-bold text-red-700">Eliminar plantilla</h1>
            <p class="text-sm text-red-600 mt-1">
                ¿Seguro que quieres eliminar la plantilla "@Model.Nombre"?
                Se borrarán también sus secciones, campos y opciones.
            </p>
        </div>

        <form asp-action="Delete" method="post">
            <input type="hidden" asp-for="Id" />

            <div class="px-6 py-5">
                <p class="text-sm text-slate-700">
                    Esta acción no se puede deshacer.
                </p>
            </div>

            <div class="px-6 py-4 border-t border-red-200 bg-red-50 flex justify-end gap-3">
                <a asp-action="Index"
                   class="px-4 py-2 text-sm font-semibold text-slate-600 hover:text-slate-900 bg-white rounded-lg border border-slate-200">
                    Cancelar
                </a>
                <button type="submit"
                        class="px-4 py-2 bg-red-600 hover:bg-red-700 text-white text-sm font-semibold
                               rounded-lg shadow-sm">
                    Sí, eliminar
                </button>
            </div>
        </form>
    </div>
</div>
