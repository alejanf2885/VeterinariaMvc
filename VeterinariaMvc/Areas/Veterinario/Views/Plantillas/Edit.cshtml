@model VeterinariaMvc.Areas.Veterinario.Models.CrearPlantillaViewModel
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Editar Plantilla";
}

<div class="max-w-xl mx-auto mt-6">
    <div class="bg-white rounded-2xl shadow border border-slate-200 overflow-hidden">
        <div class="px-6 py-4 border-b border-slate-200 bg-slate-50">
            <h1 class="text-xl font-bold text-slate-800">Editar plantilla</h1>
            <p class="text-sm text-slate-500 mt-1">
                Cambia el nombre y si la plantilla est· activa.
            </p>
        </div>

        <form asp-action="Edit" method="post">
            <div class="px-6 py-5 space-y-5">
                <div>
                    <label asp-for="Nombre" class="block text-sm font-medium text-slate-700 mb-1"></label>
                    <input asp-for="Nombre"
                           class="block w-full border border-slate-300 rounded-lg px-3 py-2 text-sm
                                  focus:ring-teal-500 focus:border-teal-500" />
                    <span asp-validation-for="Nombre" class="text-xs text-red-500 mt-1 block"></span>
                </div>

                <div class="flex items-center">
                    <input asp-for="Activa" type="checkbox"
                           class="h-4 w-4 text-teal-600 border-slate-300 rounded" />
                    <label asp-for="Activa" class="ml-2 block text-sm font-medium text-slate-700">
                        Plantilla activa
                    </label>
                </div>
            </div>

            <div class="px-6 py-4 border-t border-slate-200 bg-slate-50 flex justify-end gap-3">
                <a asp-action="Index"
                   class="px-4 py-2 text-sm font-semibold text-slate-600 hover:text-slate-900">
                    Cancelar
                </a>
                <button type="submit"
                        class="px-4 py-2 bg-teal-600 hover:bg-teal-700 text-white text-sm font-semibold
                               rounded-lg shadow-sm">
                    Guardar cambios
                </button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}
