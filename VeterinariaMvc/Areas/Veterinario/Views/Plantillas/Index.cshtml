@model List<VeterinariaMvc.Models.Plantillas.Plantilla>
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Plantillas";
}

<div class="mb-6 flex justify-between items-center">
    <div>
        <h1 class="text-2xl font-bold text-slate-800">Plantillas</h1>
        <p class="text-slate-500 mt-1">Gesti&oacute;n de plantillas para fichas cl&iacute;nicas.</p>
    </div>
    <a asp-action="Create" class="px-4 py-2 bg-teal-600 text-white font-semibold rounded-lg hover:bg-teal-700">
        Nueva Plantilla
    </a>
</div>

<div class="bg-white rounded-xl shadow-sm border border-slate-200 overflow-hidden">
    <div class="overflow-x-auto">
        <table class="w-full text-sm text-left text-slate-600">
            <thead class="text-xs uppercase bg-slate-50 text-slate-500 border-b border-slate-200">
                <tr>
                    <th class="px-6 py-3">Nombre</th>
                    <th class="px-6 py-3">Estado</th>
                    <th class="px-6 py-3">Acciones</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-slate-100">
                @if (Model != null && Model.Count > 0)
                {
                    foreach (var plantilla in Model)
                    {
                        <tr class="hover:bg-slate-50 transition">
                            <td class="px-6 py-4 font-medium text-slate-900">
                                @plantilla.Nombre
                            </td>
                            <td class="px-6 py-4">
                                @if(plantilla.Activa == true)
                                {
                                    <span class="px-2.5 py-1 text-xs font-semibold rounded-full bg-emerald-100 text-emerald-700">Activa</span>
                                }
                                else
                                {
                                    <span class="px-2.5 py-1 text-xs font-semibold rounded-full bg-red-100 text-red-700">Inactiva</span>
                                }
                            </td>
                            <td class="px-6 py-4 space-x-2">
                                <a asp-action="Details" asp-route-id="@plantilla.Id"
                                   class="text-xs font-semibold text-slate-600 hover:text-teal-700">
                                    Ver
                                </a>
                                <span class="text-slate-300">|</span>
                                <a asp-action="Edit" asp-route-id="@plantilla.Id"
                                   class="text-xs font-semibold text-slate-600 hover:text-indigo-700">
                                    Editar
                                </a>
                                <span class="text-slate-300">|</span>
                                <a asp-action="Delete" asp-route-id="@plantilla.Id"
                                   class="text-xs font-semibold text-red-600 hover:text-red-700">
                                    Eliminar
                                </a>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="3" class="px-6 py-8 text-center text-slate-500">
                            No hay plantillas registradas para esta cl&iacute;nica.
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
