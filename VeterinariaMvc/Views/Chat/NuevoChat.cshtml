@model List<VeterinariaMvc.Models.Chats.VeterinarioDisponibleViewModel>

@{
    ViewData["Title"] = "Nuevo Chat";
    var defaultImg = "https://i.imgur.com/HeIi0wU.png";
}

<div class="max-w-3xl mx-auto">
    <div class="flex items-center justify-between mb-6">
        <div>
            <h2 class="text-2xl font-bold text-slate-800">Nuevo Chat</h2>
            <p class="text-slate-500 text-sm mt-1">Selecciona un veterinario para iniciar una conversación</p>
        </div>
        <a asp-controller="Chat" asp-action="Index" asp-area=""
           class="text-sm font-semibold text-slate-600 hover:text-teal-600 transition flex items-center gap-1">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
            </svg>
            Volver a mis chats
        </a>
    </div>

    @if (Model.Count == 0)
    {
        <div class="bg-white rounded-2xl shadow-sm border border-slate-100 p-12 text-center">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-14 w-14 mx-auto text-slate-300 mb-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
            <p class="text-slate-500 text-lg font-medium">Ya tienes un chat con todos los veterinarios disponibles</p>
            <a asp-controller="Chat" asp-action="Index" asp-area=""
               class="inline-block mt-4 text-teal-600 font-semibold hover:text-teal-800 transition">
                Ir a mis conversaciones &rarr;
            </a>
        </div>
    }
    else
    {
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            @foreach (var vet in Model)
            {
                <form asp-controller="Chat" asp-action="CrearChat" asp-area="" method="post"
                      class="bg-white rounded-2xl shadow-sm border border-slate-100 p-5 flex items-center gap-4 hover:shadow-md hover:border-teal-300 transition-all cursor-pointer group">
                    <input type="hidden" name="idVeterinario" value="@vet.IdVeterinario" />
                    <img src="@(string.IsNullOrEmpty(vet.Imagen) ? defaultImg : vet.Imagen)"
                         class="h-14 w-14 rounded-full object-cover border-2 border-slate-200 group-hover:border-teal-500 transition" />
                    <div class="flex-1 min-w-0">
                        <p class="font-semibold text-slate-800 truncate">@vet.Nombre</p>
                        <p class="text-xs text-slate-500 mt-0.5">@vet.NombreClinica</p>
                        <p class="text-[10px] text-slate-400 mt-0.5">Col. @vet.NumeroColegiado</p>
                    </div>
                    <button type="submit"
                            class="bg-teal-500 hover:bg-teal-600 text-white text-sm font-semibold px-4 py-2 rounded-full transition shadow-sm whitespace-nowrap">
                        Iniciar chat
                    </button>
                </form>
            }
        </div>
    }
</div>
