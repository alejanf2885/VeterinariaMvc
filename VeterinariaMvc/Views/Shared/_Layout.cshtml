@using VeterinariaMvc.Dtos.Session
@using VeterinariaMvc.Models.Enums
@using VeterinariaMvc.Services.Estado
@inject IEstadoUsuarioService EstadoUsuarioService

@{
    // Consultamos la sesión para el Layout global
    var usuario = await EstadoUsuarioService.ObtenerUsuarioActualAsync();

    var imagenPerfil = string.IsNullOrEmpty(usuario?.Imagen)
        ? "https://i.imgur.com/HeIi0wU.png"
        : usuario.Imagen;

    // Cast del enum para mostrar el nombre del rol
    var rolNombre = usuario != null ? ((Roles)usuario.IdRol).ToString() : "";
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - VetCare</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-slate-50 text-slate-900 min-h-screen flex flex-col">

    @* Toast global para mensajes tipo "mascota desactivada" *@
    @if (ViewData["ToastMessage"] is string toastMsg)
    {
        var toastType = ViewData["ToastType"] as string ?? "success";
        var isSuccess = toastType == "success";
        <div id="global-toast"
             class="fixed bottom-4 right-4 z-50 max-w-xs w-full transform transition-all duration-300 ease-out opacity-0 translate-y-2">
            <div class="rounded-xl shadow-lg border @((isSuccess ? "border-emerald-100 bg-emerald-50" : "border-red-100 bg-red-50")) px-4 py-3 flex items-start gap-3">
                <div class="mt-1">
                    @if (isSuccess)
                    {
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-emerald-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                        </svg>
                    }
                    else
                    {
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-red-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01M4.93 4.93l14.14 14.14" />
                        </svg>
                    }
                </div>
                <div class="flex-1">
                    <p class="text-sm font-semibold @(isSuccess ? "text-emerald-900" : "text-red-900")">
                        @(isSuccess ? "Operación completada" : "Ha ocurrido un problema")
                    </p>
                    <p class="mt-0.5 text-xs @(isSuccess ? "text-emerald-800" : "text-red-800")">
                        @toastMsg
                    </p>
                </div>
                <button type="button"
                        onclick="window.hideGlobalToast()"
                        class="text-slate-400 hover:text-slate-600 transition-colors mt-1">
                    <span class="sr-only">Cerrar</span>
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
                    </svg>
                </button>
            </div>
        </div>
        <script>
            window.hideGlobalToast = function () {
                const toast = document.getElementById('global-toast');
                if (!toast) return;
                toast.classList.add('opacity-0', 'translate-y-2');
                setTimeout(() => toast.remove(), 300);
            };
            window.addEventListener('DOMContentLoaded', () => {
                const toast = document.getElementById('global-toast');
                if (!toast) return;
                // pequeña pausa para que la transición se vea fluida
                setTimeout(() => {
                    toast.classList.remove('opacity-0', 'translate-y-2');
                    toast.classList.add('opacity-100', 'translate-y-0');
                }, 50);
                // auto-ocultar a los 4 segundos
                setTimeout(window.hideGlobalToast, 4000);
            });
        </script>
    }

    <header class="sticky top-0 z-50 bg-white border-b border-slate-200 shadow-sm">
        <nav class="max-w-7xl mx-auto px-6 h-16 flex justify-between items-center">

            <a asp-area="" asp-controller="Home" asp-action="Index" class="flex items-center space-x-2 group">
                <div class="h-10 w-10 bg-teal-500 rounded-full flex items-center justify-center shadow-md group-hover:bg-teal-600 transition">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2l4 -4M12 3C7.03 3 3 7.03 3 12s4.03 9 9 9s9 -4.03 9 -9s-4.03 -9 -9 -9z" />
                    </svg>
                </div>
                <span class="text-lg font-bold text-slate-800">Vet<span class="text-teal-600">Care</span></span>
            </a>

            <div class="flex items-center space-x-6">
                @if (usuario != null)
                {
                    <div class="relative group">
                        <button class="flex items-center space-x-3 focus:outline-none py-2">
                            <div class="text-right hidden sm:block">
                                <p class="text-sm font-semibold text-slate-800 leading-tight">@usuario.Nombre</p>
                                <p class="text-xs text-teal-600 font-medium">@rolNombre</p>
                            </div>
                            <img src="@imagenPerfil" class="h-10 w-10 rounded-full object-cover border-2 border-teal-500 shadow-sm" alt="Perfil" />
                        </button>

                        <div class="absolute right-0 mt-0 w-48 bg-white border border-slate-200 rounded-xl shadow-xl opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 py-2 z-50">
                            <a asp-area="Cliente" asp-controller="Home" asp-action="Index" class="block px-4 py-2 text-sm text-slate-700 hover:bg-slate-50 hover:text-teal-600 transition">
                                Mi Panel
                            </a>
                            <div class="border-t border-slate-100 my-1"></div>
                            <form asp-area="" asp-controller="Auth" asp-action="Logout" method="post">
                                <button type="submit" class="w-full text-left block px-4 py-2 text-sm text-red-600 hover:bg-red-50 font-medium transition">
                                    Cerrar sesión
                                </button>
                            </form>
                        </div>
                    </div>
                }
                else
                {
                    <div class="flex items-center space-x-4">
                        <a asp-area="" asp-controller="Auth" asp-action="Login" class="text-slate-600 hover:text-teal-600 text-sm font-medium transition">Entrar</a>
                        <a asp-area="" asp-controller="Auth" asp-action="Register" class="bg-teal-600 text-white px-5 py-2 rounded-full text-sm font-bold hover:bg-teal-700 transition shadow-sm">Empezar</a>
                    </div>
                }
            </div>
        </nav>
    </header>

    <main class="flex-1 max-w-7xl mx-auto w-full px-6 py-8">
        @RenderBody()
    </main>

    <footer class="bg-white border-t border-slate-200">
        <div class="max-w-7xl mx-auto px-6 py-6 flex flex-col md:flex-row justify-between items-center text-sm text-slate-500 gap-4">
            <p>&copy; @DateTime.Now.Year - VetCare - Arquitectura MVC Limpia</p>
            <div class="flex gap-6">
                <a asp-area="" asp-controller="Home" asp-action="Privacy" class="hover:text-teal-600 transition">Privacidad</a>
                <a href="#" class="hover:text-teal-600 transition">Ayuda</a>
            </div>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>