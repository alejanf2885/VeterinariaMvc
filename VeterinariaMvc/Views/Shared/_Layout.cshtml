<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - VeterinariaMvc</title>
    <script type="importmap"></script>
    <!-- Solo Tailwind para comprobar que funciona -->
    <link rel="stylesheet" href="~/css/hopsersmerk.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/VeterinariaMvc.styles.css" asp-append-version="true" />
</head>
<body class="bg-slate-100 min-h-screen flex flex-col">
    <header class="bg-slate-800 text-white shadow">
        <nav class="container mx-auto flex items-center justify-between px-4 py-3">
            <a class="text-xl font-bold tracking-wide" asp-area="" asp-controller="Home" asp-action="Index">
                VeterinariaMvc
            </a>
            <ul class="flex gap-4 text-sm font-medium">
                <li>
                    <a class="hover:text-sky-300 transition-colors" asp-area="" asp-controller="Home" asp-action="Index">
                        Home
                    </a>
                </li>
                <li>
                    <a class="hover:text-sky-300 transition-colors" asp-area="" asp-controller="Home" asp-action="Privacy">
                        Privacy
                    </a>
                </li>
                <li>
                    <a class="hover:text-sky-300 transition-colors" asp-area="" asp-controller="Auth" asp-action="Login">
                        Iniciar Sesión
                    </a>
                </li>
            </ul>
        </nav>
    </header>

    <div class="container mx-auto flex-1 px-4 py-6">
        <main role="main" class="bg-white rounded-xl shadow-sm p-6">
            <div class="mb-4 border-b border-slate-200 pb-3">
                <h1 class="text-2xl font-semibold text-slate-800">
                    @ViewData["Title"]
                </h1>
                <p class="text-sm text-slate-500">
                    Layout de prueba con <span class="font-mono font-semibold text-sky-600">Tailwind CSS</span>.
                </p>
            </div>

            <div class="rounded-lg border border-dashed border-sky-400 bg-sky-50/60 p-4 mb-4">
                <p class="text-sky-900 text-sm">
                    Si ves este recuadro azul con bordes discontinuos y el header oscuro, 
                    <span class="font-semibold">Tailwind está funcionando correctamente</span>.
                </p>
            </div>

            @RenderBody()
        </main>
    </div>

    <footer class="border-t border-slate-200 bg-white">
        <div class="container mx-auto px-4 py-4 text-xs text-slate-500 flex items-center justify-between">
            <span>
                &copy; 2026 - VeterinariaMvc
            </span>
            <a class="text-sky-600 hover:text-sky-800" asp-area="" asp-controller="Home" asp-action="Privacy">
                Privacy
            </a>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
